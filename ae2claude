#!/usr/bin/env python3
"""AE2Claude CLI v3.0 - talk to After Effects from the terminal.

NOTE FOR AI AGENTS: This CLI is the primary interface to After Effects.
Use: ae2claude call <method> [args...]
Fallback: from ae_bridge import AEBridge (only when CLI can't cover your use case)

Built-in:
  ae2claude                              health check
  ae2claude jsx <code>                   run ExtendScript
  ae2claude py <code>                    run Python (PyShiftCore)
  ae2claude pixel <x> <y>                precise single-pixel sample
  ae2claude pixels <pts...>              precise multi-pixel sample
  ae2claude color <layer>                fast approximate layer color
  ae2claude colors <layers...>           fast approximate colors for many layers
  ae2claude version                      AE version
  ae2claude comps                        list compositions
  ae2claude layers                       list layers in active comp
  ae2claude run <name>                   run user script
  ae2claude scripts                      list all user scripts
  ae2claude unprecomp                    un-precompose selected layer (auto OK)
  ae2claude snapshot [path]              save current frame as PNG
  ae2claude methods                      list all bridge methods
  ae2claude help                         this help

Bridge (ae2claude call <method> [args...] [--key value]):
  Query:
    comp_info                            active comp info
    project_info                         project info
    list_layers                          all layers
    list_comps                           all compositions
    detect_solid_background_layers       detect white/gray bg layers near comp bottom
    get_layer_info <name>                layer detail
    get_layer_by_id <id>                 layer by ID
    get_selected_layers                  selected layers
    list_masks <name>                    layer masks
    list_comp_markers                    comp markers
    list_layer_markers <name>            layer markers
    list_precomps                        precomp list
    enumerate_effects <name>             layer effects
    render_queue_info                    render queue
    list_available_effects               available effects
    describe_effect <matchName>          effect detail

  Read Properties:
    get_value <name> <prop>              transform value (position/scale/...)
    get_keyframes <name> <prop>          transform keyframes
    get_effect_param <name> <idx> <key>  effect value by index
    get_effect_keyframes <n> <idx> <key> effect keyframes by index
    get_blending_mode <name>             blend mode
    get_parent <name>                    parent layer

  Create:
    add_text_layer <text>                text layer (use set_text_style for styling)
    add_solid <name> <color>             solid layer
    add_shape_layer <name>               shape layer
    add_shape_rect <name> --size [w,h]   rectangle
    add_shape_ellipse <name> --size [w,h] ellipse
    add_shape_path <name> <verts>        freeform path
    add_shape_fill <name> --color [r,g,b] fill
    add_shape_stroke <name>              stroke
    create_comp <name> <w> <h>           new comp
    create_camera <name>                 camera
    create_light <name>                  light
    create_null_control <name>           null + parent
    import_file <path>                   import footage

  Transform:
    set_value <name> <prop> <val>        set property value
    set_keyframes <name> <prop> <kfs>    set keyframes (JSON)
    apply_transform_easing <name> <prop> ease transform property

  Effect:
    add_effect <name> <type>             add effect -> returns index
    set_effect_props <n> <idx> <props>   set effect values by index
    set_effect_keyframes <n> <idx> <kfs> set effect keyframes by index
    apply_effect_easing <n> <idx> <key>  ease effect property

  Layer:
    set_blending_mode <name> <mode>      blend mode
    set_parent <child> <parent>          parenting
    remove_parent <name>                 unparent
    set_3d_layer <name>                  enable 3D
    set_track_matte <name> <matte> <type> track matte
    set_layer_timing <name>              in/out point
    set_layer_label <name> <label>       label color
    set_layer_selected <name> <bool>     selection state
    rename_layer <old> <new>             rename
    reorder_layer <name> <index>         reorder
    duplicate_layer <name>               duplicate
    remove_solid_background_layers       detect + remove white/gray bg layers
    remove_layer <name>                  delete
    deselect_all                         deselect all

  Text:
    set_text_content <name> <text>       change text
    set_text_style <name> --font X ...   font/color/size
    add_text_animator <name>             text animator
    animate_text_selector <name>         selector KFs

  Mask:
    add_mask <name> <verts>              custom mask
    set_mask_feather <name> <idx> <val>  feather
    set_mask_opacity <name> <idx> <val>  mask opacity
    animate_mask_path <name> <idx> <kfs> animate mask
    remove_mask <name> <idx>             delete mask

  Marker:
    add_comp_marker <time>               comp marker
    add_layer_marker <name> <time>       layer marker
    remove_comp_marker <idx>             delete marker

  Time:
    enable_time_remap <name>             enable remap
    freeze_frame <name> <time>           freeze
    reverse_layer <name>                 reverse
    set_expression <name> <path> <expr>  expression
    clear_expression <name> <path>       clear expr

  Render:
    add_to_render_queue                  queue active comp
    start_render                         start render
    set_render_output <idx> <path>       set output
    clear_render_queue                   clear queue

  Comp:
    precompose <names> <comp_name>       precompose
    open_precomp <name>                  open precomp
    add_comp_to_comp <src> [target]      nest comp

  Undo:
    begin_undo <name>                    start undo group
    end_undo                             end undo group
"""
import sys, json, os, urllib.request, urllib.error, inspect, threading

BASE = "http://127.0.0.1:8089"
# 项目根目录：优先用脚本所在目录，如果找不到 ae_bridge.py 则用已知路径
_SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
_BRIDGE_DIR = _SCRIPT_DIR

def req(path, data=None, timeout=15):
    r = urllib.request.Request(f"{BASE}{path}",
        data=data.encode("utf-8") if data else None,
        headers={"Content-Type": "text/plain; charset=utf-8"} if data else {})
    try:
        with urllib.request.urlopen(r, timeout=timeout) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        print(f"error: AE2Claude not reachable ({e})", file=sys.stderr)
        sys.exit(1)

def _get_bridge():
    sys.path.insert(0, _BRIDGE_DIR)
    from ae_bridge import AEBridge
    return AEBridge()

def _get_scripts_dir():
    return os.path.join(_BRIDGE_DIR, "scripts")

def _load_catalog():
    cat_path = os.path.join(_get_scripts_dir(), "catalog.json")
    if not os.path.exists(cat_path):
        return {"effects": {}, "presets": {}}
    with open(cat_path, "r", encoding="utf-8") as f:
        return json.load(f)

def _apply_effect(name):
    """Apply effect by name (fuzzy match from catalog)."""
    catalog = _load_catalog()
    effects = catalog.get("effects", {})

    # exact match
    match_name = effects.get(name)

    # fuzzy
    if not match_name:
        candidates = {k: v for k, v in effects.items() if name.lower() in k.lower()}
        if len(candidates) == 1:
            match_name = list(candidates.values())[0]
            name = list(candidates.keys())[0]
        elif len(candidates) > 1:
            print(f"Multiple matches for '{name}':", file=sys.stderr)
            for k in candidates:
                print(f"  {k}", file=sys.stderr)
            sys.exit(1)

    if not match_name:
        print(f"error: effect '{name}' not in catalog. Use 'ae2claude fx --list'", file=sys.stderr)
        sys.exit(1)

    print(f"→ {name} ({match_name})", file=sys.stderr)
    jsx = (
        f'(function(){{'
        f'var c=app.project.activeItem;'
        f'if(!c||!(c instanceof CompItem))return"ERR:no_comp";'
        f'var s=c.selectedLayers;if(s.length===0)return"ERR:no_selection";'
        f'app.beginUndoGroup("Add {name}");'
        f'for(var i=0;i<s.length;i++){{try{{s[i].property("Effects").addProperty("{match_name}");}}catch(e){{}}}}'
        f'app.endUndoGroup();return"added:"+s.length;'
        f'}})()'
    )
    r = req("/jsx", jsx)
    if r.get("ok"):
        result = r.get("result", "")
        if result and result.startswith("ERR:"):
            print(result, file=sys.stderr); sys.exit(1)
        if result: print(result)
    else:
        print(f"error: {r.get('error', 'unknown')}", file=sys.stderr); sys.exit(1)

def _apply_preset(name):
    """Apply preset by name (fuzzy match from catalog)."""
    catalog = _load_catalog()
    presets = catalog.get("presets", {})

    path = presets.get(name)
    if not path:
        candidates = {k: v for k, v in presets.items() if name.lower() in k.lower()}
        if len(candidates) == 1:
            path = list(candidates.values())[0]
            name = list(candidates.keys())[0]
        elif len(candidates) > 1:
            print(f"Multiple matches for '{name}':", file=sys.stderr)
            for k in candidates: print(f"  {k}", file=sys.stderr)
            sys.exit(1)

    if not path:
        print(f"error: preset '{name}' not in catalog. Use 'ae2claude preset --list'", file=sys.stderr)
        sys.exit(1)

    print(f"→ {name}", file=sys.stderr)
    # Resolve relative paths: try project dir first, then AE Presets folder
    if not os.path.isabs(path):
        local_path = os.path.join(_BRIDGE_DIR, path)
        if os.path.exists(local_path):
            path = local_path
    path_escaped = path.replace("\\", "/")
    jsx = (
        f'(function(){{'
        f'var c=app.project.activeItem;'
        f'if(!c||!(c instanceof CompItem))return"ERR:no_comp";'
        f'var s=c.selectedLayers;if(s.length===0)return"ERR:no_selection";'
        f'app.beginUndoGroup("Apply {name}");'
        f'var f=new File("{path_escaped}");'
        f'if(!f.exists){{var base=new Folder(app.path).parent.fsName.replace(/\\\\/g,"/")+"/Presets/";'
        f'f=new File(base+"{path_escaped}");}}if(!f.exists)return"ERR:preset_not_found";'
        f'for(var i=0;i<s.length;i++){{s[i].applyPreset(f);}}'
        f'app.endUndoGroup();return"applied:"+s.length;'
        f'}})()'
    )
    r = req("/jsx", jsx)
    if r.get("ok"):
        result = r.get("result", "")
        if result and result.startswith("ERR:"):
            print(result, file=sys.stderr); sys.exit(1)
        if result: print(result)
    else:
        print(f"error: {r.get('error', 'unknown')}", file=sys.stderr); sys.exit(1)

def _load_registry():
    reg_path = os.path.join(_get_scripts_dir(), "registry.json")
    if not os.path.exists(reg_path):
        return []
    with open(reg_path, "r", encoding="utf-8") as f:
        return json.load(f)

def _run_script(name, mode=None):
    """Run a user script by slug (fuzzy match). mode: default/ctrl/alt"""
    registry = _load_registry()
    scripts_dir = _get_scripts_dir()

    # exact match first
    match = None
    for s in registry:
        if s["slug"] == name or s["name"] == name:
            match = s; break

    # fuzzy: substring match
    if not match:
        candidates = [s for s in registry if name in s["slug"] or name in s["name"]]
        if len(candidates) == 1:
            match = candidates[0]
        elif len(candidates) > 1:
            print(f"Multiple matches for '{name}':", file=sys.stderr)
            for c in candidates:
                print(f"  {c['slug']}  ({c['name']})", file=sys.stderr)
            sys.exit(1)

    if not match:
        print(f"error: script '{name}' not found. Use 'ae2claude scripts' to list.", file=sys.stderr)
        sys.exit(1)

    fpath = os.path.join(scripts_dir, match["file"])
    for enc in ("utf-8", "gbk", "latin-1"):
        try:
            with open(fpath, "r", encoding=enc) as f:
                code = f.read()
            break
        except (UnicodeDecodeError, ValueError):
            continue

    # Inject __mode__ if specified
    if mode and mode != "default":
        code = f'var __mode__ = "{mode}";\n' + code

    note = match.get("note", "")
    mode_str = f" [mode={mode}]" if mode and mode != "default" else ""
    print(f"→ {match['name']}{mode_str}{('  ' + note) if note else ''}", file=sys.stderr)

    r = req("/jsx", code, timeout=30)
    if r.get("ok"):
        result = r.get("result", "")
        if result and result != "undefined":
            if result.startswith("ERR:"):
                print(result, file=sys.stderr)
                sys.exit(1)
            print(result)
    else:
        print(f"error: {r.get('error', 'unknown')}", file=sys.stderr)
        sys.exit(1)

def _list_scripts():
    """List all available user scripts."""
    registry = _load_registry()
    if not registry:
        print("No scripts found. Run export_mobar.py first.")
        return
    for s in registry:
        note = s.get('note', '')
        suffix = f"  {note}" if note else ""
        print(f"  {s['slug']:40s} {s['name']}{suffix}")
    print(f"\n共 {len(registry)} 个脚本 — 用 ae2claude run <名称> 执行")

def _parse_arg(s):
    """Try to parse as JSON, fallback to string."""
    try:
        return json.loads(s)
    except (json.JSONDecodeError, ValueError):
        return s

def _split_call_args(args):
    """Split CLI args into positional / kwargs for bridge calls."""
    positional = []
    kwargs = {}
    i = 0
    while i < len(args):
        if args[i].startswith("--"):
            key = args[i][2:].replace("-", "_")
            if i + 1 < len(args) and not args[i + 1].startswith("--"):
                kwargs[key] = _parse_arg(args[i + 1])
                i += 2
            else:
                kwargs[key] = True
                i += 1
        else:
            positional.append(_parse_arg(args[i]))
            i += 1
    return positional, kwargs

def _print_method_result(result):
    if isinstance(result, (dict, list)):
        print(json.dumps(result, indent=2, ensure_ascii=False))
    elif result is not None:
        s = str(result)
        if s.startswith("ERR:"):
            print(s, file=sys.stderr)
            sys.exit(1)
        print(s)

def _invoke_method(method_name, positional=None, kwargs=None):
    ae = _get_bridge()
    method = getattr(ae, method_name, None)
    if method is None:
        print(f"error: unknown method '{method_name}'", file=sys.stderr)
        print(f"hint: ae2claude methods", file=sys.stderr)
        sys.exit(1)

    positional = positional or []
    kwargs = kwargs or {}

    try:
        result = method(*positional, **kwargs)
        _print_method_result(result)
    except Exception as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)

def _call_method(method_name, args):
    positional, kwargs = _split_call_args(args)
    _invoke_method(method_name, positional=positional, kwargs=kwargs)

def _normalize_points_args(positional):
    """Normalize pixels command arguments into [[x, y], ...]."""
    if len(positional) == 1 and isinstance(positional[0], list):
        raw_points = positional[0]
    else:
        if len(positional) < 2 or len(positional) % 2 != 0:
            raise ValueError("pixels needs either [[x,y], ...] or flat x y pairs")
        raw_points = [
            [positional[i], positional[i + 1]]
            for i in range(0, len(positional), 2)
        ]

    points = []
    for pt in raw_points:
        if not isinstance(pt, (list, tuple)) or len(pt) != 2:
            raise ValueError("points must be [[x, y], ...]")
        points.append([int(pt[0]), int(pt[1])])
    return points

def _normalize_layers_args(positional):
    """Normalize colors command arguments into [layer, ...]."""
    if len(positional) == 1 and isinstance(positional[0], list):
        raw_layers = positional[0]
    else:
        raw_layers = positional

    if not raw_layers:
        raise ValueError("colors needs at least one layer")

    layers = []
    for layer in raw_layers:
        if isinstance(layer, float) and layer.is_integer():
            layer = int(layer)
        if not isinstance(layer, (int, str)):
            raise ValueError("layers must be indices or names")
        layers.append(layer)
    return layers

def _list_methods():
    ae = _get_bridge()
    methods = []
    for name in sorted(dir(ae)):
        if name.startswith("_"):
            continue
        m = getattr(ae, name)
        if callable(m):
            sig = inspect.signature(m)
            params = [str(p) for p in sig.parameters.values()]
            methods.append(f"  {name}({', '.join(params)})")
    print("\n".join(methods))

def _ensure_comp():
    """Check if there's an active comp; if no comps exist, create a default one."""
    r = req("/jsx",
        '(function(){var n=0;for(var i=1;i<=app.project.numItems;i++)'
        '{if(app.project.item(i) instanceof CompItem)n++;}return n;})()')
    count = int(r.get("result", "0")) if r.get("ok") else 0
    if count == 0:
        print("No comp found, creating default 1920x1080 30fps 10s...", file=sys.stderr)
        r2 = req("/jsx",
            'var c=app.project.items.addComp("Comp 1",1920,1080,1,10,30);c.openInViewer();c.name')
        if r2.get("ok"):
            print(f"Created: {r2.get('result', '')}", file=sys.stderr)

def main():
    args = sys.argv[1:]
    if not args:
        r = req("/")
        print(json.dumps(r, indent=2, ensure_ascii=False))
        return

    cmd = args[0]

    if cmd == "jsx":
        code = " ".join(args[1:]) if len(args) > 1 else sys.stdin.read()
        r = req("/jsx", code)
    elif cmd == "py":
        code = " ".join(args[1:]) if len(args) > 1 else sys.stdin.read()
        r = req("/", code)
        # py 输出统一：优先 output，其次 result（去引号）
        if r.get("ok"):
            out = r.get("output", "").strip()
            res = r.get("result", "")
            if isinstance(res, str):
                res = res.strip("'\"")
            if out:
                print(out)
            elif res and res != "None":
                print(res)
            return
        else:
            print(f"error: {r.get('error', 'unknown')}", file=sys.stderr)
            sys.exit(1)
    elif cmd == "version":
        r = req("/jsx", "app.version")
    elif cmd == "comps":
        r = req("/jsx",
            'var r=[];for(var i=1;i<=app.project.numItems;i++){var it=app.project.item(i);'
            'if(it instanceof CompItem)r.push(it.name);}r.join("\\n")')
    elif cmd == "layers":
        _ensure_comp()
        r = req("/jsx",
            'var c=app.project.activeItem;if(!c)"no active comp";'
            'else{var r=[];for(var i=1;i<=c.numLayers;i++)r.push(i+": "+c.layer(i).name);r.join("\\n")}')
    elif cmd == "pixel":
        _ensure_comp()
        positional, kwargs = _split_call_args(args[1:])
        if len(positional) != 2:
            print("usage: ae2claude pixel <x> <y> [--time T]", file=sys.stderr)
            sys.exit(1)
        _invoke_method("sample_pixel", positional=positional, kwargs=kwargs)
        return
    elif cmd == "pixels":
        _ensure_comp()
        positional, kwargs = _split_call_args(args[1:])
        try:
            points = _normalize_points_args(positional)
        except ValueError as e:
            print(f"usage: ae2claude pixels <x1> <y1> [x2 y2 ...] [--time T]", file=sys.stderr)
            print(f"       ae2claude pixels '[[x1,y1],[x2,y2]]' [--time T]", file=sys.stderr)
            print(f"error: {e}", file=sys.stderr)
            sys.exit(1)
        _invoke_method("sample_pixels", positional=[points], kwargs=kwargs)
        return
    elif cmd == "color":
        _ensure_comp()
        positional, kwargs = _split_call_args(args[1:])
        if len(positional) != 1:
            print("usage: ae2claude color <layer> [--time T] [--max-dimension N] [--tolerance N]", file=sys.stderr)
            sys.exit(1)
        _invoke_method("approximate_layer_color", positional=positional, kwargs=kwargs)
        return
    elif cmd == "colors":
        _ensure_comp()
        positional, kwargs = _split_call_args(args[1:])
        try:
            layers = _normalize_layers_args(positional)
        except ValueError as e:
            print("usage: ae2claude colors <layer1> [layer2 ...] [--time T] [--max-dimension N] [--tolerance N]", file=sys.stderr)
            print("       ae2claude colors '[31,32,\"Layer Name\"]' [--time T] [--max-dimension N] [--tolerance N]", file=sys.stderr)
            print(f"error: {e}", file=sys.stderr)
            sys.exit(1)
        _invoke_method("approximate_layers_color", positional=[layers], kwargs=kwargs)
        return
    elif cmd in ("health", "status"):
        r = req("/")
        print(json.dumps(r, indent=2, ensure_ascii=False))
        return
    elif cmd == "call":
        if len(args) < 2:
            print("usage: ae2claude call <method> [args...]", file=sys.stderr)
            sys.exit(1)
        if args[1] != "create_comp":
            _ensure_comp()
        _call_method(args[1], args[2:])
        return
    elif cmd == "run":
        _ensure_comp()
        if len(args) < 2:
            print("usage: ae2claude run <script-name> [--mode ctrl|alt]", file=sys.stderr)
            print("       ae2claude scripts  — list available scripts", file=sys.stderr)
            sys.exit(1)
        mode = "default"
        if "--mode" in args:
            mi = args.index("--mode")
            if mi + 1 < len(args):
                mode = args[mi + 1]
                args = args[:mi] + args[mi+2:]
        _run_script(args[1], mode=mode)
        return
    elif cmd == "scripts":
        _list_scripts()
        return
    elif cmd == "fx":
        if len(args) < 2 or args[1] == "--list":
            catalog = _load_catalog()
            for name, mn in sorted(catalog.get("effects", {}).items()):
                print(f"  {name:35s} {mn}")
            print(f"\n共 {len(catalog.get('effects', {}))} 个效果 — ae2claude fx <名称>")
            return
        _apply_effect(args[1])
        return
    elif cmd == "preset":
        if len(args) < 2 or args[1] == "--list":
            catalog = _load_catalog()
            for name, path in sorted(catalog.get("presets", {}).items()):
                print(f"  {name:35s} {os.path.basename(path)}")
            print(f"\n共 {len(catalog.get('presets', {}))} 个预设 — ae2claude preset <名称>")
            return
        _apply_preset(args[1])
        return
    elif cmd == "unprecomp":
        _ensure_comp()
        # 1. get layer count before
        r0 = req("/jsx", 'app.project.activeItem.numLayers')
        if not r0.get("ok"):
            print("error: no active comp", file=sys.stderr); sys.exit(1)
        n_before = int(r0["result"])
        # 2. find menu command id dynamically
        r_id = req("/jsx", 'app.findMenuCommandId("Un-PreCompose...")')
        if not r_id.get("ok") or r_id.get("result", "0") == "0":
            print("error: Un-PreCompose script not installed", file=sys.stderr); sys.exit(1)
        cmd_id = r_id["result"]
        # 3. background thread: click OK on the modal dialog
        def _click_dialog():
            import ctypes, ctypes.wintypes, time
            u32 = ctypes.windll.user32
            EnumWindows = u32.EnumWindows
            GetWindowTextW = u32.GetWindowTextW
            IsWindowVisible = u32.IsWindowVisible
            SetForegroundWindow = u32.SetForegroundWindow
            PostMessageW = u32.PostMessageW
            WNDENUMPROC = ctypes.WINFUNCTYPE(ctypes.c_bool, ctypes.wintypes.HWND, ctypes.wintypes.LPARAM)
            WM_KEYDOWN, WM_KEYUP, VK_RETURN = 0x0100, 0x0101, 0x0D
            for _ in range(150):  # 30s max
                found = [None]
                def cb(hwnd, _lp):
                    if IsWindowVisible(hwnd):
                        buf = ctypes.create_unicode_buffer(256)
                        GetWindowTextW(hwnd, buf, 256)
                        if "Un-Precompose" in buf.value:
                            found[0] = hwnd
                            return False
                    return True
                EnumWindows(WNDENUMPROC(cb), 0)
                if found[0]:
                    time.sleep(0.3)
                    SetForegroundWindow(found[0])
                    time.sleep(0.1)
                    PostMessageW(found[0], WM_KEYDOWN, VK_RETURN, 0)
                    PostMessageW(found[0], WM_KEYUP, VK_RETURN, 0)
                    return
                time.sleep(0.2)
        t = threading.Thread(target=_click_dialog, daemon=True)
        t.start()
        # 4. execute (blocks until dialog dismissed)
        req("/jsx", f'app.executeCommand({cmd_id})', timeout=30)
        t.join(timeout=5)
        # 5. remove last 2 residual layers (null + original comp)
        r1 = req("/jsx", 'app.project.activeItem.numLayers')
        if r1.get("ok"):
            n_after = int(r1["result"])
            if n_after > n_before:
                req("/jsx",
                    '(function(){var c=app.project.activeItem;var n=c.numLayers;'
                    'c.layer(n).remove();c.layer(n-1).remove();return"ok"})()')
        print("un-precomposed", file=sys.stderr)
        return
    elif cmd == "snapshot":
        _ensure_comp()
        out = args[1] if len(args) > 1 else os.path.join(os.environ.get("TEMP", "/tmp"), "ae_snapshot.png")
        out = out.replace("\\", "/")
        r = req("/jsx",
            f'(function(){{var c=app.project.activeItem;if(!c)return"ERR:no_comp";'
            f'var f=new File("{out}");c.saveFrameToPng(c.time,f);return f.fsName;}})()',
            timeout=30)
        if r.get("ok"):
            result = r.get("result", "")
            if result and result.startswith("ERR:"):
                print(result, file=sys.stderr); sys.exit(1)
            if result: print(result)
        else:
            print(f"error: {r.get('error', 'unknown')}", file=sys.stderr); sys.exit(1)
        return
    elif cmd == "methods":
        _list_methods()
        return
    elif cmd in ("help", "-h", "--help"):
        print(__doc__.strip())
        return
    elif cmd == "--version":
        print("ae2claude 3.1.0")
        return
    elif cmd == "info":
        # 快捷: 当前合成概况
        r = req("/jsx",
            'var c=app.project.activeItem;if(!c)"no active comp";else{'
            'JSON.stringify({name:c.name,width:c.width,height:c.height,'
            'fps:1/c.frameDuration,duration:c.duration,numLayers:c.numLayers,'
            'time:c.time})}')
    else:
        # treat entire args as jsx
        r = req("/jsx", " ".join(args))

    if r.get("ok"):
        result = r.get("result", "")
        if result:
            print(result)
    else:
        print(f"error: {r.get('error', 'unknown')}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
